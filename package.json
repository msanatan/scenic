{
  "name": "@unibridge/monorepo",
  "version": "0.5.0",
  "description": "Interact with Unity via TypeScript and the command line!",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:sdk && npm run build:cli",
    "build:sdk": "npm run build --workspace=@unibridge/sdk",
    "build:cli": "npm run build --workspace=@unibridge/cli",
    "test": "npm run test:sdk && npm run test:cli",
    "test:sdk": "npm run test --workspace=@unibridge/sdk",
    "test:cli": "npm run test --workspace=@unibridge/cli",
    "test:integration": "npm run build && node --test 'integration/sdk/*.test.ts' 'integration/cli/*.test.ts'",
    "test:integration:sdk": "npm run build:sdk && node --test 'integration/sdk/*.test.ts'",
    "test:integration:cli": "npm run build:cli && node --test 'integration/cli/*.test.ts'",
    "test:local": "npm run build && npm run test",
    "smoke:execute": "node packages/cli/dist/index.js execute -p \"TestProjects/UniBridge3Dv6.3\" \"UnityEngine.Debug.Log(\\\"unibridge smoke test\\\");\"",
    "bump": "node scripts/bump-version.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msanatan/unibridge.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/msanatan/unibridge/issues"
  },
  "homepage": "https://github.com/msanatan/unibridge#readme",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}
