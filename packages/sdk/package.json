{
  "name": "@scenicai/sdk",
  "version": "1.4.0",
  "description": "Scenic is a TypeScript SDK for interacting with the Unity Editor.",
  "main": "./dist/index.js",
  "scripts": {
    "test": "node --test src/*.test.ts src/**/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "unity",
    "sdk",
    "automation",
    "tooling",
    "ai"
  ],
  "author": {
    "name": "Marcus Sanatan",
    "url": "https://gameboymarcus.com"
  },
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msanatan/scenic.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/msanatan/scenic/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/msanatan/scenic/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands/*": {
      "types": "./dist/commands/*/index.d.ts",
      "default": "./dist/commands/*/index.js"
    }
  },
  "dependencies": {
    "valibot": "^1.2.0"
  }
}
